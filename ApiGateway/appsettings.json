{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.AspNetCore.Routing": "Debug",
      "Yarp": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "products-api": {
        "ClusterId": "products-service",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      },
      "products-openapi": {
        "ClusterId": "products-service",
        "Match": {
          "Path": "/openapi/{**catch-all}"
        }
      },
      "products-images": {
        "ClusterId": "products-service",
        "Match": {
          "Path": "/images/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "products-service": {
        "Destinations": {
          "default": {
            "Address": "http://localhost:5221/"
          }
        }
      }
    }
  }
}
